# Stock Value Screener — environment template.
# v1 needs NO secrets: all data comes from free, keyless sources
# (yfinance / Yahoo, FRED public CSV). Copy to .env only if you need to
# override a default below.

# CORS origin for the frontend dev server (Vite default is 5173).
# CORS_ORIGINS=http://localhost:5173

# --- Optional future paid data provider (NOT used in v1) -------------------
# A pluggable provider seam exists; if you later add a paid source, put its
# key here. Nothing in v1 reads it.
# DATA_PROVIDER_API_KEY=
